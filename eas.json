{
    "cli": {
        "version": ">= 19.0.8",
        "appVersionSource": "local"
    },
    "build": {
        "base": {
            "node": "24.11.1",
            "credentialsSource": "local"
        },
        "development": {
            "extends": "base",
            "developmentClient": true,
            "distribution": "internal"
        },
        "apk": {
            "extends": "base",
            "autoIncrement": true,
            "android": {
                "buildType": "apk"
            }
        },
        "aab": {
            "extends": "base",
            "credentialsSource": "local",
            "android": {
                "buildType": "app-bundle"
            }
        }
    }
}
